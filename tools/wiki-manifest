#!/usr/bin/env python3
"""wiki-manifest — emit the source-anchor manifest the Graphify bridge consumes.

Reads every unit's `source:` frontmatter in a wiki dir and writes a manifest.json
of {slug, repo, path, symbol, provenance} anchors. In the per-repo model the bridge
joins these onto the repo-local Graphify code graph.

  wiki-manifest <wiki-dir> [--out <wiki-dir>/manifest.json] [--repo <name>]

--repo defaults each anchor's repo to the given name when the frontmatter omits it
(per-repo wikis usually anchor into their own repo). Requires PyYAML.
"""
from __future__ import annotations
import argparse, datetime, json, sys
from pathlib import Path
try:
    import yaml
except ImportError:
    print("wiki-manifest: needs PyYAML"); sys.exit(2)

def split_frontmatter(text):
    if not text.startswith("---"):
        return None
    end = text.find("\n---", 3)
    return text[3:end].strip() if end != -1 else None

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("wiki_dir", type=Path)
    ap.add_argument("--out", type=Path)
    ap.add_argument("--repo", default=None)
    a = ap.parse_args()
    out = a.out or (a.wiki_dir / "manifest.json")

    anchors = []
    for f in sorted(a.wiki_dir.glob("*.md")):
        fm_raw = split_frontmatter(f.read_text(encoding="utf-8"))
        if not fm_raw:
            continue
        try:
            fm = yaml.safe_load(fm_raw) or {}
        except yaml.YAMLError:
            continue
        src = fm.get("source")
        if not src:
            continue
        for s in (src if isinstance(src, list) else [src]):
            if not isinstance(s, dict):
                continue
            anchors.append({
                "slug": f.stem,
                "repo": s.get("repo") or a.repo or "",
                "path": s.get("path"),
                "symbol": s.get("symbol"),
                "provenance": s.get("provenance"),
            })
    manifest = {"owner": a.repo or "", "generated": datetime.date.today().isoformat(),
                "anchors": anchors}
    out.write_text(json.dumps(manifest, indent=2, ensure_ascii=False), encoding="utf-8")
    print(f"wiki-manifest: {len(anchors)} anchors from {a.wiki_dir} → {out}")

if __name__ == "__main__":
    main()
