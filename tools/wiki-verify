#!/usr/bin/env python3
"""wiki-verify — check that each unit's source anchors still resolve in the repo.

Deterministic drift gate for PR CI — needs only python3 + pyyaml (NO graphify venv).
Catches the classic rot: a unit anchors to code that was renamed/moved/deleted.

  wiki-verify <wiki-dir> --repo-root <path> [--strict]

For each unit's `source:` anchor that points at a file:
  - path missing in the repo            → ERROR (blocks)
  - identifier symbol not found in file → WARNING (renamed/moved? shown, not blocking)
Ticket/ADR refs (e.g. "PROJ-123") and prose symbols (e.g. "Deploy section") are skipped.
--strict promotes symbol warnings to errors. Exit 1 on errors.
"""
from __future__ import annotations
import argparse, re, sys
from pathlib import Path
try:
    import yaml
except ImportError:
    print("wiki-verify: needs PyYAML"); sys.exit(2)

SLUG_RE = re.compile(r"^[a-z0-9]+(-[a-z0-9]+)*$")
IDENT_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")

def split_fm(text):
    if not text.startswith("---"):
        return None
    end = text.find("\n---", 3)
    return text[3:end].strip() if end != -1 else None

def looks_like_file(p: str) -> bool:
    # A file path has a slash or an extension; a ticket/ADR ref ("PROJ-123") has neither.
    return ("/" in p) or ("." in Path(p).name)

def split_symbols(sym):
    return [s.strip() for s in re.split(r"[/,]", sym or "") if s.strip()]

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("wiki_dir", type=Path)
    ap.add_argument("--repo-root", type=Path, default=Path("."))
    ap.add_argument("--strict", action="store_true")
    a = ap.parse_args()

    errs, warns, n = [], [], 0
    for f in sorted(a.wiki_dir.glob("*.md")):
        if not SLUG_RE.match(f.stem):
            continue
        fm_raw = split_fm(f.read_text(encoding="utf-8"))
        if not fm_raw:
            continue
        try:
            fm = yaml.safe_load(fm_raw) or {}
        except yaml.YAMLError:
            continue
        src = fm.get("source")
        if not src:
            continue
        n += 1
        for s in (src if isinstance(src, list) else [src]):
            if not isinstance(s, dict):
                continue
            path = s.get("path")
            if not path or not looks_like_file(path):
                continue  # ticket/ADR ref — not a file anchor
            full = a.repo_root / path
            if not full.exists():
                errs.append(f"{f.stem}: source path '{path}' not found in repo")
                continue
            txt = None
            for sym in split_symbols(s.get("symbol")):
                if not IDENT_RE.match(sym):
                    continue  # prose/section name — can't grep deterministically
                if txt is None:
                    txt = full.read_text(encoding="utf-8", errors="ignore")
                if not re.search(r"\b" + re.escape(sym) + r"\b", txt):
                    warns.append(f"{f.stem}: symbol '{sym}' not found in {path} (renamed/moved?)")

    for w in warns:
        print(f"WARN  {w}")
    for e in errs:
        print(f"ERROR {e}")
    fail = bool(errs) or (a.strict and bool(warns))
    print(f"\nwiki-verify: {n} anchored units, {len(errs)} broken paths, "
          f"{len(warns)} stale symbols" + (" [strict]" if a.strict else ""))
    sys.exit(1 if fail else 0)

if __name__ == "__main__":
    main()
